  <metadata>
    <id>primedictate</id>
    <version>0.0.0</version>
    <title>PrimeDictate</title>
    <authors>FlowDevs</authors>
    <projectUrl>https://github.com/flowdevs-io/PrimeDictate</projectUrl>
    <projectSourceUrl>https://github.com/flowdevs-io/PrimeDictate</projectSourceUrl>
    <bugTrackerUrl>https://github.com/flowdevs-io/PrimeDictate/issues</bugTrackerUrl>
    <docsUrl>https://www.flowdevs.io/portfolio/project/primedictate-local-ai-dictation-app</docsUrl>
