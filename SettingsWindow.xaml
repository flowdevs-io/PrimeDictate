<Window x:Class="PrimeDictate.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:ClassModifier="internal"
        Title="PrimeDictate Settings"
        Width="660"
        Height="760"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        PreviewKeyDown="OnWindowPreviewKeyDown"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Foreground="{DynamicResource TextPrimaryBrush}">
    <Border Background="{DynamicResource WindowBackgroundBrush}"
            CornerRadius="12"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Custom Title Bar -->
            <Grid Background="Transparent" MouseLeftButtonDown="OnTitleBarMouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Name="HeaderText"
                           Margin="20,16,0,16"
                           FontSize="16"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Text="PrimeDictate settings" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top" Margin="0,8,8,0">
                    <Button Width="32" Height="32" Content="—" Background="Transparent" BorderThickness="0" Click="OnMinimizeClick" ToolTip="Minimize" />
                    <Button Width="32" Height="32" Content="✕" Background="Transparent" BorderThickness="0" Click="OnCloseClick" ToolTip="Close" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Margin="20,0,20,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Name="HeaderSubtextText"
                           Margin="0,0,0,0"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap"
                           Text="Manage your local model, commands, and dictation behavior." />

                <TabControl Name="SetupTabControl"
                            Grid.Row="1"
                            Margin="0,16,0,0"
                            SelectionChanged="OnSetupTabSelectionChanged">
            <TabItem Name="WelcomeTab" Header="Overview">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="14">
                        <Border Padding="14"
                                Background="{StaticResource HeroCardBackgroundBrush}"
                                BorderBrush="{StaticResource HeroCardBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10">
                            <StackPanel>
                                <TextBlock FontSize="16"
                                           FontWeight="SemiBold"
                                           Text="Built for fast Windows text editing" />
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"
                                           Text="PrimeDictate is tuned for dictating into editors, chat apps, documentation tools, terminals, and browser text fields. You pick a local transcription backend and model, set your hotkey, and the app types the final transcript directly into the focused app." />
                            </StackPanel>
                        </Border>

                        <TextBlock Margin="0,18,0,0"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Text="Quick setup checklist" />

                        <Border Margin="0,10,0,0"
                                Padding="12"
                                Background="{StaticResource SurfaceElevatedBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <TextBlock TextWrapping="Wrap">
                                <Run FontWeight="SemiBold" Text="1. Pick a local transcription model" />
                                <LineBreak />
                                <Run Text="Use the Model tab to choose Whisper or Parakeet, download a model locally, or browse to one you already have." />
                            </TextBlock>
                        </Border>

                        <Border Margin="0,10,0,0"
                                Padding="12"
                                Background="{StaticResource SurfaceElevatedBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <TextBlock TextWrapping="Wrap">
                                <Run FontWeight="SemiBold" Text="2. Set your dictation hotkey" />
                                <LineBreak />
                                <Run Text="PrimeDictate listens globally, so you can start and stop dictation without changing apps." />
                            </TextBlock>
                        </Border>

                        <Border Margin="0,10,0,0"
                                Padding="12"
                                Background="{StaticResource SurfaceElevatedBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <TextBlock TextWrapping="Wrap">
                                <Run FontWeight="SemiBold" Text="3. Tune how commits behave" />
                                <LineBreak />
                                <Run Text="Choose silence auto-commit timing, optional coding-mode Enter, and mic capture behavior for your workflow." />
                            </TextBlock>
                        </Border>

                        <StackPanel Margin="0,22,0,0">
                            <TextBlock Text="General dictation behavior" FontWeight="SemiBold" />
                            <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                                <TextBlock VerticalAlignment="Center" Text="Commit after" />
                                <TextBox Name="AutoCommitSilenceSecondsTextBox"
                                         Width="48"
                                         Margin="8,0,8,0"
                                         VerticalContentAlignment="Center" />
                                <TextBlock VerticalAlignment="Center" Text="seconds of silence (0 = hotkey only)" />
                            </StackPanel>
                            <CheckBox Name="SendEnterAfterCommitCheckBox"
                                      Margin="0,10,0,0"
                                      Content="Send Enter after committing transcript" />
                            <CheckBox Name="PlayAudioCuesCheckBox"
                                      Margin="0,10,0,0"
                                      Content="Play start and stop tones" />
                            <CheckBox Name="CheckForUpdatesAutomaticallyCheckBox"
                                      Margin="0,10,0,0"
                                      Content="Check GitHub Releases for software updates automatically" />
                            <TextBlock Margin="0,8,0,0"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       TextWrapping="Wrap"
                                       Text="Emergency stop shortcuts and stop phrases discard the active capture without typing text. Use silence auto-commit or the start / stop shortcut when you want to commit." />
                        </StackPanel>

                        <Border Name="FirstRunDownloadHintBorder"
                                Margin="0,14,0,0"
                                Padding="14"
                                Background="{StaticResource HeroCardBackgroundBrush}"
                                BorderBrush="{StaticResource HeroCardBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock FontSize="14"
                                           FontWeight="SemiBold"
                                           Text="Ready to download your first model" />
                                <TextBlock Name="FirstRunDownloadHintText"
                                           Margin="0,6,0,0"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <TextBlock Name="WelcomeFooterText"
                                   Margin="0,18,0,0"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Text="You can revisit any of these settings from the tray icon later." />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Name="ModelTab" Header="Model">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="14">
                        <TextBlock FontSize="15"
                                    FontWeight="SemiBold"
                                   Text="Choose a transcription backend and model" />
                        <TextBlock Margin="0,8,0,0"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Text="PrimeDictate supports multiple local speech engines. Pick the backend you want to use, then choose the model that fits your Windows workflow and download it locally or browse to an existing install." />

                        <TextBlock Margin="0,14,0,0"
                                   FontWeight="SemiBold"
                                   Text="Transcription backend" />
                        <ComboBox Name="ModelBackendComboBox"
                                  Margin="0,6,0,0"
                                  MinHeight="32"
                                  SelectionChanged="OnModelBackendChanged" />
                        <TextBlock Name="ModelBackendDescriptionText"
                                   Margin="0,8,0,0"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap" />

                        <TextBlock Margin="0,12,0,0"
                                   FontWeight="SemiBold"
                                   Text="Compute interface" />
                        <ComboBox Name="ComputeInterfaceComboBox"
                                  Margin="0,6,0,0"
                                  MinHeight="32"
                                  SelectionChanged="OnComputeInterfaceChanged" />
                        <TextBlock Name="ComputeInterfaceDescriptionText"
                                   Margin="0,8,0,0"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap" />

                        <TextBlock Margin="0,14,0,0"
                                   FontWeight="SemiBold"
                                   Text="Model" />
                        <ComboBox Name="ModelChoiceComboBox"
                                  Margin="0,6,0,0"
                                  MinHeight="32"
                                  SelectionChanged="OnModelChoiceChanged" />

                        <Border Margin="0,12,0,0"
                                Padding="14"
                                Background="{StaticResource SurfaceElevatedBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10">
                            <StackPanel>
                                <DockPanel LastChildFill="False">
                                    <TextBlock Name="ModelChoiceTitleText"
                                               FontSize="15"
                                               FontWeight="SemiBold" />
                                    <Border Name="RecommendedBadgeBorder"
                                            DockPanel.Dock="Right"
                                            Padding="8,3"
                                            Background="{StaticResource RecommendedBadgeBackgroundBrush}"
                                            CornerRadius="999"
                                            Visibility="Collapsed">
                                        <TextBlock Text="Recommended"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource RecommendedBadgeForegroundBrush}" />
                                    </Border>
                                </DockPanel>

                                <TextBlock Name="ModelChoiceMetaText"
                                           Margin="0,8,0,0"
                                           Foreground="{StaticResource TextSecondaryBrush}" />

                                <TextBlock Name="ModelChoiceDescriptionText"
                                           Margin="0,8,0,0"
                                           TextWrapping="Wrap" />

                                <TextBlock Name="ModelChoiceStatusText"
                                           Margin="0,12,0,0"
                                           Foreground="{StaticResource StatusInfoForegroundBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <StackPanel Margin="0,12,0,0" Orientation="Horizontal">
                            <Button Name="DownloadSelectedModelButton"
                                    Width="140"
                                    Content="Download model"
                                    Click="OnDownloadSelectedModelClick" />
                            <Button Name="CancelModelDownloadButton"
                                    Width="90"
                                    Margin="10,0,0,0"
                                    Content="Cancel"
                                    Click="OnCancelModelDownloadClick"
                                    Visibility="Collapsed" />
                            <Button Name="BrowseModelPathButton"
                                    Width="120"
                                    Margin="10,0,0,0"
                                    Content="Browse..."
                                    Click="OnBrowseModelPathClick" />
                        </StackPanel>

                        <ProgressBar Name="ModelDownloadProgressBar"
                                     Height="14"
                                     Margin="0,12,0,0"
                                     Minimum="0"
                                     Maximum="100"
                                     Visibility="Collapsed" />

                        <TextBlock Name="ModelDownloadStatusText"
                                   Margin="0,8,0,0"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Visibility="Collapsed" />

                        <TextBlock Name="ModelPathLabelText"
                                   Margin="0,18,0,0"
                                   FontWeight="SemiBold"
                                   Text="Resolved model path" />
                        <TextBox Name="ModelPathTextBox"
                                  Margin="0,6,0,0"
                                  TextChanged="OnModelPathTextChanged"
                                  ToolTip="Use a downloaded model or browse to an existing local model install." />
                        <TextBlock Name="ModelStorageHintText"
                                   Margin="0,8,0,0"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Name="PreferencesTab" Header="Commands">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="14">
                        <TextBlock FontSize="15"
                                   FontWeight="SemiBold"
                                   Text="Keyboard, voice, and computer commands" />
                        <TextBlock Margin="0,8,0,0"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Text="Configure the phrases and keyboard shortcuts that control dictation, open history, or run local command prompt actions." />

                        <CheckBox Name="EnableVoiceCommandsCheckBox"
                                  Margin="0,14,0,0"
                                  Content="Listen for command phrases while dictating" />

                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="155" />
                                <ColumnDefinition Width="128" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="96" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       Text="Command" />
                            <TextBlock Grid.Row="0"
                                       Grid.Column="1"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       Text="Keyboard" />
                            <TextBlock Grid.Row="0"
                                       Grid.Column="2"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       Text="Voice phrase" />

                            <TextBlock Grid.Row="1"
                                       Margin="0,10,0,0"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold"
                                       Text="Start / stop dictation" />
                            <TextBlock Name="DictationHotkeyValueText"
                                       Grid.Row="1"
                                       Grid.Column="1"
                                       Margin="0,10,0,0"
                                       VerticalAlignment="Center" />
                            <TextBox Name="VoiceDictationPhraseTextBox"
                                     Grid.Row="1"
                                     Grid.Column="2"
                                     Margin="0,10,8,0"
                                     VerticalContentAlignment="Center"
                                     ToolTip="While recording, saying this phrase commits the dictation." />
                            <Button Name="CaptureDictationHotkeyButton"
                                    Grid.Row="1"
                                    Grid.Column="3"
                                    Width="96"
                                    Margin="0,10,0,0"
                                    Content="Change"
                                    Tag="Dictation"
                                    Click="OnCaptureHotkeyClick" />

                            <TextBlock Grid.Row="2"
                                       Margin="0,10,0,0"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold"
                                       Text="Emergency stop" />
                            <TextBlock Name="StopHotkeyValueText"
                                       Grid.Row="2"
                                       Grid.Column="1"
                                       Margin="0,10,0,0"
                                       VerticalAlignment="Center" />
                            <TextBox Name="VoiceStopPhraseTextBox"
                                     Grid.Row="2"
                                     Grid.Column="2"
                                     Margin="0,10,8,0"
                                     VerticalContentAlignment="Center" />
                            <Button Name="CaptureStopHotkeyButton"
                                    Grid.Row="2"
                                    Grid.Column="3"
                                    Width="96"
                                    Margin="0,10,0,0"
                                    Content="Change"
                                    Tag="Stop"
                                    Click="OnCaptureHotkeyClick" />

                            <TextBlock Grid.Row="3"
                                       Margin="0,10,0,0"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold"
                                       Text="Open history" />
                            <TextBlock Name="HistoryHotkeyValueText"
                                       Grid.Row="3"
                                       Grid.Column="1"
                                       Margin="0,10,0,0"
                                       VerticalAlignment="Center" />
                            <TextBox Name="VoiceHistoryPhraseTextBox"
                                     Grid.Row="3"
                                     Grid.Column="2"
                                     Margin="0,10,8,0"
                                     VerticalContentAlignment="Center" />
                            <Button Name="CaptureHistoryHotkeyButton"
                                    Grid.Row="3"
                                    Grid.Column="3"
                                    Width="96"
                                    Margin="0,10,0,0"
                                    Content="Change"
                                    Tag="History"
                                    Click="OnCaptureHotkeyClick" />
                        </Grid>
                        <TextBlock Name="HotkeyHintText"
                                   Margin="0,8,0,0"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Text="Click Change, then press Ctrl/Shift/Alt plus a key." />

                        <StackPanel Margin="0,22,0,0">
                            <TextBlock Margin="0,16,0,0"
                                       FontWeight="SemiBold"
                                       Text="Computer commands" />
                            <TextBlock Margin="0,6,0,0"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       TextWrapping="Wrap"
                                       Text="Say a phrase anywhere in the final transcript. Stop runs the command and ends the commit; Continue removes the phrase and commits the remaining dictated text." />
                            <DataGrid Name="VoiceShellCommandsDataGrid"
                                      Height="170"
                                      Margin="0,10,0,0"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      HeadersVisibility="Column">
                                <DataGrid.Columns>
                                    <DataGridCheckBoxColumn Header="On"
                                                            Binding="{Binding Enabled, UpdateSourceTrigger=PropertyChanged}"
                                                            Width="54" />
                                    <DataGridTextColumn Header="Say"
                                                        Binding="{Binding Phrase, UpdateSourceTrigger=PropertyChanged}"
                                                        Width="*" />
                                    <DataGridComboBoxColumn x:Name="VoiceShellCommandBehaviorColumn"
                                                            Header="After"
                                                            SelectedItemBinding="{Binding CompletionBehavior, UpdateSourceTrigger=PropertyChanged}"
                                                            Width="96" />
                                    <DataGridTextColumn Header="Command Prompt command"
                                                        Binding="{Binding Command, UpdateSourceTrigger=PropertyChanged}"
                                                        Width="2*" />
                                </DataGrid.Columns>
                            </DataGrid>
                            <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                                <Button Name="AddVoiceShellCommandButton"
                                        Width="112"
                                        Content="Add command"
                                        Click="OnAddVoiceShellCommandClick" />
                                <Button Name="RemoveVoiceShellCommandButton"
                                        Width="120"
                                        Margin="10,0,0,0"
                                        Content="Remove selected"
                                        Click="OnRemoveVoiceShellCommandClick" />
                            </StackPanel>
                        </StackPanel>

                        <Expander Margin="0,22,0,0"
                                  Header="Advanced settings"
                                  Foreground="{StaticResource TextPrimaryBrush}">
                            <StackPanel Margin="0,12,0,0">
                                <TextBlock Text="Tray icon click behavior" FontWeight="SemiBold" />
                                <ComboBox Name="TrayBehaviorComboBox"
                                          Margin="0,6,0,0"
                                          SelectedIndex="1">
                                    <ComboBoxItem Content="Single click opens Workspace" Tag="Single" />
                                    <ComboBoxItem Content="Double click opens Workspace" Tag="Double" />
                                </ComboBox>

                                <TextBlock Margin="0,16,0,0" Text="Start with Windows" FontWeight="SemiBold" />
                                <ComboBox Name="LaunchAtLoginComboBox"
                                          Margin="0,6,0,0"
                                          SelectedIndex="1">
                                    <ComboBoxItem Content="Off" Tag="Disabled" />
                                    <ComboBoxItem Content="Current user" Tag="CurrentUser" />
                                    <ComboBoxItem Content="All users" Tag="AllUsers" />
                                </ComboBox>
                                <TextBlock Margin="0,6,0,0"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           TextWrapping="Wrap"
                                           Text="Current user writes shell:startup. All users writes shell:common startup and may ask for administrator approval." />

                                <TextBlock Margin="0,16,0,0" Text="Microphone" FontWeight="SemiBold" />
                                <ComboBox Name="InputDeviceComboBox"
                                          Margin="0,6,0,0"
                                          MinHeight="32" />
                                <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                                    <TextBlock VerticalAlignment="Center" Text="Input gain" />
                                    <TextBox Name="InputGainTextBox"
                                             Width="58"
                                             Margin="8,0,8,0"
                                             VerticalContentAlignment="Center" />
                                    <TextBlock VerticalAlignment="Center" Text="x" />
                                </StackPanel>
                                <CheckBox Name="ExclusiveMicAccessCheckBox"
                                          Margin="0,8,0,0"
                                          Content="Request exclusive mic access while dictating" />

                                <TextBlock Margin="0,16,0,0" Text="Overlay and target" FontWeight="SemiBold" />
                                <ComboBox Name="OverlayModeComboBox"
                                          Margin="0,6,0,0">
                                    <ComboBoxItem Content="Compact microphone" Tag="Compact" />
                                    <ComboBoxItem Content="Full transcript panel" Tag="Full" />
                                </ComboBox>
                                <CheckBox Name="ReturnToStartTargetCheckBox"
                                          Margin="0,10,0,0"
                                          Content="Return final transcript to the starting window" />

                                <TextBlock Margin="0,16,0,0" Text="Ollama post-processing" FontWeight="SemiBold" />
                                <CheckBox Name="EnableOllamaCheckBox"
                                          Margin="0,6,0,0"
                                          Content="Enable local Ollama formatting" />
                                <StackPanel Margin="0,6,0,0" Orientation="Horizontal">
                                    <TextBlock VerticalAlignment="Center" Text="Endpoint" Width="70" />
                                    <TextBox Name="OllamaEndpointTextBox" Width="220" VerticalContentAlignment="Center" />
                                </StackPanel>
                                <StackPanel Margin="0,6,0,0" Orientation="Horizontal">
                                    <TextBlock VerticalAlignment="Center" Text="Model" Width="70" />
                                    <TextBox Name="OllamaModelTextBox" Width="140" VerticalContentAlignment="Center" />
                                </StackPanel>
                                <StackPanel Margin="0,6,0,0" Orientation="Horizontal">
                                    <TextBlock VerticalAlignment="Center" Text="Mode" Width="70" />
                                    <ComboBox Name="OllamaModeComboBox" Width="220" VerticalContentAlignment="Center">
                                        <ComboBoxItem Content="Default (Grammar &amp; Spelling)" Tag="Default" />
                                        <ComboBoxItem Content="Prompt (AI Prompt Engineer)" Tag="Prompt" />
                                        <ComboBoxItem Content="Bug Report (QA Engineer)" Tag="Bug" />
                                        <ComboBoxItem Content="Update (Changelog/Status)" Tag="Update" />
                                        <ComboBoxItem Content="Communication (Email/Message)" Tag="Communication" />
                                        <ComboBoxItem Content="Blog (Draft/Post)" Tag="Blog" />
                                        <ComboBoxItem Content="Vibe Coding (Agent Instructions)" Tag="VibeCoding" />
                                    </ComboBox>
                                </StackPanel>
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Name="ReplacementsTab" Header="Replacements">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="14">
                        <TextBlock FontSize="15"
                                   FontWeight="SemiBold"
                                   Text="Transcript tuning" />
                        <TextBlock Margin="0,8,0,0"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Text="After transcription, replace phrases in the final text before optional AI polish and typing. Matching is case-insensitive; longer phrases are applied first." />
                        <DataGrid Name="ReplacementRulesDataGrid"
                                  Height="260"
                                  Margin="0,14,0,0"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Find"
                                                    Binding="{Binding Find, UpdateSourceTrigger=PropertyChanged}"
                                                    Width="*" />
                                <DataGridTextColumn Header="Replace with"
                                                    Binding="{Binding Replace, UpdateSourceTrigger=PropertyChanged}"
                                                    Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                            <Button Name="AddReplacementRuleButton"
                                    Width="88"
                                    Content="Add rule"
                                    Click="OnAddReplacementRuleClick" />
                            <Button Name="RemoveReplacementRuleButton"
                                    Width="120"
                                    Margin="10,0,0,0"
                                    Content="Remove selected"
                                    Click="OnRemoveReplacementRuleClick" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Name="ImpactTab" Header="Impact">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="14">
                        <TextBlock FontSize="15"
                                   FontWeight="SemiBold"
                                   Text="Dictation impact" />
                        <TextBlock Margin="0,8,0,0"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Text="Local stats are counted from successful transcript commits and stay on this PC." />

                        <UniformGrid Margin="0,16,0,0" Columns="2" Rows="2">
                            <Border Margin="0,0,8,8"
                                    Padding="14"
                                    CornerRadius="8"
                                    BorderBrush="#5038BDF8"
                                    BorderThickness="1">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#3338BDF8" Offset="0" />
                                        <GradientStop Color="#220F172A" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <StackPanel>
                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Words typed" />
                                    <TextBlock Name="StatsTotalWordsText" FontSize="28" FontWeight="SemiBold" />
                                </StackPanel>
                            </Border>
                            <Border Margin="8,0,0,8"
                                    Padding="14"
                                    CornerRadius="8"
                                    BorderBrush="#50A78BFA"
                                    BorderThickness="1">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#33A78BFA" Offset="0" />
                                        <GradientStop Color="#22111827" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <StackPanel>
                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Net time saved" />
                                    <TextBlock Name="StatsTimeSavedText" FontSize="28" FontWeight="SemiBold" />
                                </StackPanel>
                            </Border>
                            <Border Margin="0,8,8,0"
                                    Padding="14"
                                    CornerRadius="8"
                                    BorderBrush="#5034D399"
                                    BorderThickness="1">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#3334D399" Offset="0" />
                                        <GradientStop Color="#22111827" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <StackPanel>
                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Average speech pace" />
                                    <TextBlock Name="StatsAverageWpmText" FontSize="28" FontWeight="SemiBold" />
                                </StackPanel>
                            </Border>
                            <Border Margin="8,8,0,0"
                                    Padding="14"
                                    CornerRadius="8"
                                    BorderBrush="#50F59E0B"
                                    BorderThickness="1">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#33F59E0B" Offset="0" />
                                        <GradientStop Color="#22111827" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <StackPanel>
                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Successful sessions" />
                                    <TextBlock Name="StatsSessionCountText" FontSize="28" FontWeight="SemiBold" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <StackPanel Margin="0,18,0,0" Orientation="Horizontal">
                            <TextBlock VerticalAlignment="Center" Text="Compare against typing at" />
                            <TextBox Name="BaselineTypingSpeedTextBox"
                                     Width="54"
                                     Margin="8,0,8,0"
                                     VerticalContentAlignment="Center" />
                            <TextBlock VerticalAlignment="Center" Text="WPM" />
                        </StackPanel>

                        <TextBlock Margin="0,18,0,0"
                                   FontWeight="SemiBold"
                                   Text="Last 14 days" />
                        <ItemsControl Name="DailyStatsItemsControl" Margin="0,10,0,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Rows="1" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="2,0" VerticalAlignment="Bottom">
                                        <TextBlock Text="{Binding Words}"
                                                   FontSize="10"
                                                   HorizontalAlignment="Center"
                                                   Foreground="{StaticResource TextMutedBrush}" />
                                        <Border Height="118"
                                                Margin="0,4,0,4"
                                                Background="{StaticResource SurfaceElevatedBrush}"
                                                CornerRadius="5"
                                                VerticalAlignment="Bottom">
                                            <Border Height="{Binding BarHeight}"
                                                    VerticalAlignment="Bottom"
                                                    Background="{Binding Fill}"
                                                    CornerRadius="5" />
                                        </Border>
                                        <TextBlock Text="{Binding Label}"
                                                   FontSize="10"
                                                   HorizontalAlignment="Center"
                                                   Foreground="{StaticResource TextMutedBrush}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Margin="0,18,0,0"
                                   FontWeight="SemiBold"
                                   Text="Achievements" />
                        <ItemsControl Name="AchievementItemsControl" Margin="0,8,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8"
                                            Padding="12"
                                            Background="{StaticResource SurfaceElevatedBrush}"
                                            BorderBrush="{Binding Accent}"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                        <DockPanel LastChildFill="True">
                                            <TextBlock DockPanel.Dock="Right"
                                                       Margin="14,0,0,0"
                                                       Foreground="{Binding Accent}"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding Status}" />
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
                                                <TextBlock Margin="0,4,0,0"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           TextWrapping="Wrap"
                                                           Text="{Binding Detail}" />
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

                <Grid Grid.Row="2" Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button Name="HistoryButton"
                            Width="120"
                            Content="View history"
                            Click="OnHistoryClick" />

                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button Name="BackButton"
                                Width="92"
                                Margin="0,0,10,0"
                                Content="Back"
                                Click="OnBackClick"
                                Visibility="Collapsed" />
                        <Button Name="CancelButton"
                                Width="92"
                                Margin="0,0,10,0"
                                Content="Cancel"
                                Click="OnCancelClick" />
                        <Button Name="SaveButton"
                                Width="92"
                                IsDefault="True"
                                Content="Save"
                                Click="OnSaveClick" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
